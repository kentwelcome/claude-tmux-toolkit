{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/capture-window.sh",
            "timeout": 2,
            "statusMessage": "Capturing tmux window..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/nvim-open.sh",
            "timeout": 5,
            "statusMessage": "Syncing nvim sidebar..."
          }
        ]
      }
    ]
  }
}
